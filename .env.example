# Copy to .env and fill in. Never commit real secrets.

# API
NODE_ENV=development
PORT=3001

# Database (Postgres)
DATABASE_URL=postgresql://splitsmart:splitsmart@localhost:5432/splitsmart?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# Auth (OIDC). For LOCAL DEV, run `pnpm --filter @splitsmart/api dev:auth`
# and use the values below. For production, point these at your Auth0/Clerk tenant.
AUTH_ISSUER_URL=http://localhost:3999/
AUTH_AUDIENCE=splitsmart-api
AUTH_JWKS_URI=http://localhost:3999/jwks.json

# Observability (all optional; unset = disabled)
# OTEL_TRACES_CONSOLE=1                 # print OpenTelemetry spans to stdout
# OTEL_EXPORTER_OTLP_ENDPOINT=          # or export spans to an OTLP collector
# SENTRY_DSN=                           # server error tracking

# Web
NEXT_PUBLIC_API_URL=http://localhost:3001

# Mobile
EXPO_PUBLIC_API_URL=http://localhost:3001
