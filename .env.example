# Copy to .env and fill in. Never commit real secrets.

# API
NODE_ENV=development
PORT=3001

# Database (Postgres)
DATABASE_URL=postgresql://splitsmart:splitsmart@localhost:5432/splitsmart?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# Auth (OIDC provider) — placeholders, fill per provider
AUTH_ISSUER_URL=
AUTH_AUDIENCE=
AUTH_JWKS_URI=

# Web
NEXT_PUBLIC_API_URL=http://localhost:3001

# Mobile
EXPO_PUBLIC_API_URL=http://localhost:3001
