{
  "name": "@splitsmart/validation",
  "version": "0.0.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@splitsmart/config": "workspace:*",
    "@splitsmart/types": "workspace:*",
    "@types/node": "^20.16.10",
    "eslint": "^9.11.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  }
}
