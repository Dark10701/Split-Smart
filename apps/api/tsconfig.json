{
  "extends": "@splitsmart/config/tsconfig/node.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "target": "ES2022",
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "strictPropertyInitialization": false,
    "types": ["node", "jest"]
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"],
  // Keep the dev watcher out of build output: each compile rewrites dist/
  // (deleteOutDir), and watching it causes an endless recompile→restart loop
  // that makes the API flap. OneDrive sync churn amplifies this.
  "watchOptions": {
    "excludeDirectories": ["**/node_modules", "dist"]
  }
}
